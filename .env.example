# ============================================================================
# AIRTABLE CONFIGURATION
# ============================================================================
# Get these from your Airtable account at https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_api_key_here
AIRTABLE_BASE_ID=your_base_id_here

# Table names (defaults provided, adjust if different)
AIRTABLE_DESIGNS_TABLE=Designs
AIRTABLE_COLORS_TABLE=Colors

# ============================================================================
# PHOTOSHOP & EXTENDSCRIPT
# ============================================================================
# Path to Photoshop executable (adjust version number as needed)
PHOTOSHOP_EXE=C:/Program Files/Adobe/Adobe Photoshop 2024/Photoshop.exe

# Path to the ExtendScript file (relative to this repo)
COMPOSER_JSX=C:/psd-composer/composer.jsx

# ============================================================================
# TEMPLATE DIRECTORIES (one per batch type)
# ============================================================================
# These should contain .psd template files for each batch
TEMPLATES_DIR_MAIN=C:/psd-composer/assets/templates/main
TEMPLATES_DIR_MARKETING=C:/psd-composer/assets/templates/marketing
TEMPLATES_DIR_PRINT=C:/psd-composer/assets/templates/print

# ============================================================================
# OUTPUT CONFIGURATION
# ============================================================================
# Base directory where all output folders will be created
OUTPUT_BASE_DIR=C:/psd-composer/assets/output

# Folder structure created:
# {design_name}/
#   00 - CSV/
#   00 - MARKETING/          (from marketing batch)
#   01 - ORIGINAL/           (from main batch)
#     Apparel/
#     Accessories/
#   02 - OPTIMIZED/          (compressed JPGs from Pillow)
#   03 - ART FILES/
#   Print-Files/             (from print batch)

# ============================================================================
# FTP UPLOAD CONFIGURATION
# ============================================================================
# Leave blank to skip FTP upload
FTP_HOST=ftp.example.com
FTP_USER=username
FTP_PASS=password

# Base path on FTP server (files will be uploaded to: {FTP_BASE_PATH}/{artist_name}/{design_name}/)
FTP_BASE_PATH=uploads/DTG

# ============================================================================
# IMAGE COMPRESSION
# ============================================================================
# JPEG quality for compressed exports (0-95, default 85)
JPG_QUALITY=85

# ============================================================================
# POLLING CONFIGURATION
# ============================================================================
# Interval in seconds between Airtable polls (default 60)
POLL_INTERVAL=60
